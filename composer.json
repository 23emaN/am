{
    "require": {
        "php": "8.0.16",
        "firebase/php-jwt": "^6.0",
        "fpdf/fpdf": "^1.84",
        "mpdf/mpdf": "^8.3",
        "phpmailer/phpmailer": "^7.1",
        "phpoffice/phpspreadsheet": "^1.20",
        "vimeo/vimeo-api": "^4.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "platform": {
            "php": "8.0.16"
        },
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
